# ACP — Agent Collaboration Platform
# Copy this file to .env and fill in your values.

# ── API Server ──────────────────────────────────────────────
PORT=3001
VIBESQL_URL=http://localhost:5173          # Local VibeSQL micro, or https://api.idealvibe.online
VIBESQL_DIRECT_URL=http://localhost:5173
VIBESQL_CONTAINER_SECRET=                  # VibeSQL auth secret
VIBE_API_URL=https://api.idealvibe.online  # Vibe Public API
VIBE_CLIENT_ID=                            # Your Vibe client ID
VIBE_HMAC_KEY=                             # Your Vibe HMAC signing key
REDIS_URL=redis://localhost:6379

# ── Desktop Shell (Vite) ───────────────────────────────────
VITE_IDP_URL=https://idp.payez.net         # IDP for auth
VITE_PAYEZ_CLIENT_SECRET=                  # IDP client secret

# ── Agent Config ────────────────────────────────────────────
ACP_AGENTS=DotNetPert,BAPert,NextPert,QAPert
ACP_AUTO_SPAWN=false
