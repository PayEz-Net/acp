{
  "name": "agent-collaboration-platform",
  "version": "0.1.0",
  "description": "Desktop application for orchestrating AI agent collaboration",
  "main": "dist/main/index.js",
  "author": "PayEz <dev@payez.net>",
  "license": "MIT",
  "scripts": {
    "kill-port": "powershell -Command \"Get-NetTCPConnection -LocalPort 40010,40011 -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force -ErrorAction SilentlyContinue }\"",
    "dev": "vite",
    "dev:electron": "tsc -p tsconfig.main.json && concurrently -k \"vite\" \"wait-on http://localhost:40010 && electron .\"",
    "build": "tsc && vite build",
    "build:electron": "npm run build && tsc -p tsconfig.main.json",
    "electron": "electron .",
    "start": "npm run build:electron && electron .",
    "dist": "npm run build:electron && electron-builder",
    "dist:win": "npm run dist -- --win",
    "dist:mac": "npm run dist -- --mac",
    "dist:linux": "npm run dist -- --linux"
  },
  "dependencies": {
    "@microsoft/signalr": "^10.0.0",
    "electron-store": "^8.1.0",
    "lucide-react": "^0.294.0",
    "node-pty": "^1.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0",
    "zustand": "^4.5.0"
  },
  "build": {
    "appId": "net.payez.agent-collaboration-platform",
    "productName": "ACP",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  }
}
